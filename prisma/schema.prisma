generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ═══════════════════════════════════════════
// 📊 EXISTING MODELS
// ═══════════════════════════════════════════

model UserSettings {
  id                  Int      @id @default(1)
  currentMiningCoin   String   @default("KAS")
  electricityPrice    Float    @default(0.12)
  switchThreshold     Float    @default(8.0)
  safeMode            Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model DecisionLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  coin        String
  action      String
  score       Float
  risk        String
  reason      String
  fromCoin    String?
  toCoin      String?

  @@index([timestamp])
  @@index([action])
}

model AlertLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  type        String
  title       String
  message     String
  coin        String?
  read        Boolean  @default(false)

  @@index([timestamp])
  @@index([read])
}

model ProfitLog {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  coin        String
  amountUSD   Float
  hashrate    Float?
  power       Float?

  @@index([date])
}

// ═══════════════════════════════════════════
// 🎯 RADAR MODULE - New Coin Discovery
// ═══════════════════════════════════════════

model MineableCoin {
  id                String   @id @default(cuid())
  symbol            String   @unique
  name              String
  algorithm         String

  gpuMineable       Boolean  @default(true)
  minVramGB         Int?

  price             Float?
  marketCap         Float?
  volume24h         Float?
  priceChange24h    Float?

  networkHashrate   Float?
  difficulty        Float?
  blockReward       Float?
  blockTimeSeconds  Int?

  liquidityScore    Float?
  listingCount      Int?
  status            String   @default("active")

  dataSource        String
  reliability       String
  lastUpdated       DateTime @default(now())
  firstSeenAt       DateTime @default(now())

  snapshots         CoinSnapshot[]
  opportunities     Opportunity[]

  @@index([status])
  @@index([gpuMineable])
}

model CoinSnapshot {
  id              String       @id @default(cuid())
  coinSymbol      String
  coin            MineableCoin @relation(fields: [coinSymbol], references: [symbol])

  price           Float?
  marketCap       Float?
  volume24h       Float?
  difficulty      Float?
  networkHashrate Float?

  source          String
  capturedAt      DateTime     @default(now())

  @@index([coinSymbol, capturedAt])
}

model Opportunity {
  id              String       @id @default(cuid())
  coinSymbol      String
  coin            MineableCoin @relation(fields: [coinSymbol], references: [symbol])

  type            String
  score           Float
  riskLevel       String
  audience        String
  timeframe       String

  signal          String
  reasoning       String
  risks           String

  dataSource      String
  confidence      Float

  detectedAt      DateTime     @default(now())
  expiresAt       DateTime?
  status          String       @default("active")

  @@index([status, score])
  @@index([type])
}